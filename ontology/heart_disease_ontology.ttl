@prefix hdo: <http://example.org/heart-disease-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix schema: <http://schema.org/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dbr: <http://dbpedia.org/resource/> .
@prefix dbo: <http://dbpedia.org/ontology/> .

# =============================================================================
# Ontology Declaration
# =============================================================================
<http://example.org/heart-disease-ontology> rdf:type owl:Ontology ;
    rdfs:label "Heart Disease Ontology"@en ;
    rdfs:comment "An OWL ontology for the Heart Disease domain, designed to represent patient clinical data for heart disease prediction. Based on the UCI Heart Disease dataset."@en ;
    dct:creator "LOD Application Project" ;
    dct:created "2026-04-17"^^xsd:date ;
    owl:versionInfo "1.0" .

# =============================================================================
# Classes
# =============================================================================

# --- Core Classes ---
hdo:Patient rdf:type owl:Class ;
    rdfs:label "Patient"@en ;
    rdfs:comment "A person who has undergone clinical examination for heart disease assessment."@en ;
    rdfs:subClassOf foaf:Person .

hdo:Diagnosis rdf:type owl:Class ;
    rdfs:label "Diagnosis"@en ;
    rdfs:comment "The result of a heart disease diagnostic assessment."@en .

hdo:ClinicalMeasurement rdf:type owl:Class ;
    rdfs:label "Clinical Measurement"@en ;
    rdfs:comment "A collection of clinical test results and medical measurements taken from a patient."@en .

# --- Enumeration Classes ---
hdo:ChestPainType rdf:type owl:Class ;
    rdfs:label "Chest Pain Type"@en ;
    rdfs:comment "Classification of chest pain experienced by the patient. Types include: Typical Angina (0), Atypical Angina (1), Non-anginal Pain (2), and Asymptomatic (3)."@en .

hdo:ECGResult rdf:type owl:Class ;
    rdfs:label "ECG Result"@en ;
    rdfs:comment "Classification of resting electrocardiographic results. Types include: Normal (0), ST-T Wave Abnormality (1), and Left Ventricular Hypertrophy (2)."@en .

hdo:STSlope rdf:type owl:Class ;
    rdfs:label "ST Slope"@en ;
    rdfs:comment "The slope of the peak exercise ST segment. Types include: Upsloping (0), Flat (1), and Downsloping (2)."@en .

hdo:ThalassemiaType rdf:type owl:Class ;
    rdfs:label "Thalassemia Type"@en ;
    rdfs:comment "Classification of thalassemia (a blood disorder). Types include: Normal (1), Fixed Defect (2), and Reversible Defect (3)."@en .

# =============================================================================
# Object Properties
# =============================================================================

hdo:hasDiagnosis rdf:type owl:ObjectProperty ;
    rdfs:label "has diagnosis"@en ;
    rdfs:comment "Links a patient to their heart disease diagnosis result."@en ;
    rdfs:domain hdo:Patient ;
    rdfs:range hdo:Diagnosis .

hdo:hasMeasurement rdf:type owl:ObjectProperty ;
    rdfs:label "has measurement"@en ;
    rdfs:comment "Links a patient to their clinical measurement data."@en ;
    rdfs:domain hdo:Patient ;
    rdfs:range hdo:ClinicalMeasurement .

hdo:hasChestPainType rdf:type owl:ObjectProperty ;
    rdfs:label "has chest pain type"@en ;
    rdfs:comment "Specifies the type of chest pain experienced by the patient."@en ;
    rdfs:domain hdo:Patient ;
    rdfs:range hdo:ChestPainType .

hdo:hasECGResult rdf:type owl:ObjectProperty ;
    rdfs:label "has ECG result"@en ;
    rdfs:comment "Specifies the resting electrocardiographic result of the patient."@en ;
    rdfs:domain hdo:ClinicalMeasurement ;
    rdfs:range hdo:ECGResult .

hdo:hasSTSlope rdf:type owl:ObjectProperty ;
    rdfs:label "has ST slope"@en ;
    rdfs:comment "Specifies the slope of the peak exercise ST segment."@en ;
    rdfs:domain hdo:ClinicalMeasurement ;
    rdfs:range hdo:STSlope .

hdo:hasThalassemia rdf:type owl:ObjectProperty ;
    rdfs:label "has thalassemia type"@en ;
    rdfs:comment "Specifies the thalassemia classification of the patient."@en ;
    rdfs:domain hdo:Patient ;
    rdfs:range hdo:ThalassemiaType .

# =============================================================================
# Datatype Properties
# =============================================================================

hdo:patientId rdf:type owl:DatatypeProperty ;
    rdfs:label "patient ID"@en ;
    rdfs:comment "A unique identifier for the patient."@en ;
    rdfs:domain hdo:Patient ;
    rdfs:range xsd:integer .

hdo:age rdf:type owl:DatatypeProperty ;
    rdfs:label "age"@en ;
    rdfs:comment "The age of the patient in years."@en ;
    rdfs:domain hdo:Patient ;
    rdfs:range xsd:integer .

hdo:sex rdf:type owl:DatatypeProperty ;
    rdfs:label "sex"@en ;
    rdfs:comment "The biological sex of the patient (Male or Female)."@en ;
    rdfs:domain hdo:Patient ;
    rdfs:range xsd:string .

hdo:restingBP rdf:type owl:DatatypeProperty ;
    rdfs:label "resting blood pressure"@en ;
    rdfs:comment "Resting blood pressure in mm Hg on admission to the hospital."@en ;
    rdfs:domain hdo:ClinicalMeasurement ;
    rdfs:range xsd:integer .

hdo:cholesterol rdf:type owl:DatatypeProperty ;
    rdfs:label "serum cholesterol"@en ;
    rdfs:comment "Serum cholesterol level in mg/dl."@en ;
    rdfs:domain hdo:ClinicalMeasurement ;
    rdfs:range xsd:integer .

hdo:fastingBS rdf:type owl:DatatypeProperty ;
    rdfs:label "fasting blood sugar"@en ;
    rdfs:comment "Whether fasting blood sugar is greater than 120 mg/dl (true/false)."@en ;
    rdfs:domain hdo:ClinicalMeasurement ;
    rdfs:range xsd:boolean .

hdo:maxHR rdf:type owl:DatatypeProperty ;
    rdfs:label "maximum heart rate"@en ;
    rdfs:comment "Maximum heart rate achieved during exercise."@en ;
    rdfs:domain hdo:ClinicalMeasurement ;
    rdfs:range xsd:integer .

hdo:exerciseAngina rdf:type owl:DatatypeProperty ;
    rdfs:label "exercise-induced angina"@en ;
    rdfs:comment "Whether the patient experienced exercise-induced angina (true/false)."@en ;
    rdfs:domain hdo:ClinicalMeasurement ;
    rdfs:range xsd:boolean .

hdo:oldpeak rdf:type owl:DatatypeProperty ;
    rdfs:label "oldpeak"@en ;
    rdfs:comment "ST depression induced by exercise relative to rest."@en ;
    rdfs:domain hdo:ClinicalMeasurement ;
    rdfs:range xsd:float .

hdo:numMajorVessels rdf:type owl:DatatypeProperty ;
    rdfs:label "number of major vessels"@en ;
    rdfs:comment "Number of major vessels (0-3) colored by fluoroscopy."@en ;
    rdfs:domain hdo:ClinicalMeasurement ;
    rdfs:range xsd:integer .

hdo:hasHeartDisease rdf:type owl:DatatypeProperty ;
    rdfs:label "has heart disease"@en ;
    rdfs:comment "Whether the patient has been diagnosed with heart disease (true/false)."@en ;
    rdfs:domain hdo:Diagnosis ;
    rdfs:range xsd:boolean .

# =============================================================================
# Named Individuals - Chest Pain Types
# =============================================================================

hdo:TypicalAngina rdf:type owl:NamedIndividual , hdo:ChestPainType ;
    rdfs:label "Typical Angina"@en ;
    rdfs:comment "Chest pain that is typical of heart-related angina (cp=0)."@en .

hdo:AtypicalAngina rdf:type owl:NamedIndividual , hdo:ChestPainType ;
    rdfs:label "Atypical Angina"@en ;
    rdfs:comment "Chest pain that is atypical of heart-related angina (cp=1)."@en .

hdo:NonAnginalPain rdf:type owl:NamedIndividual , hdo:ChestPainType ;
    rdfs:label "Non-anginal Pain"@en ;
    rdfs:comment "Non-anginal chest pain (cp=2)."@en .

hdo:Asymptomatic rdf:type owl:NamedIndividual , hdo:ChestPainType ;
    rdfs:label "Asymptomatic"@en ;
    rdfs:comment "No chest pain symptoms (cp=3)."@en .

# =============================================================================
# Named Individuals - ECG Results
# =============================================================================

hdo:NormalECG rdf:type owl:NamedIndividual , hdo:ECGResult ;
    rdfs:label "Normal"@en ;
    rdfs:comment "Normal resting electrocardiographic result (restecg=0)."@en .

hdo:STTWaveAbnormality rdf:type owl:NamedIndividual , hdo:ECGResult ;
    rdfs:label "ST-T Wave Abnormality"@en ;
    rdfs:comment "Having ST-T wave abnormality (T wave inversions and/or ST elevation or depression of > 0.05 mV) (restecg=1)."@en .

hdo:LeftVentricularHypertrophy rdf:type owl:NamedIndividual , hdo:ECGResult ;
    rdfs:label "Left Ventricular Hypertrophy"@en ;
    rdfs:comment "Showing probable or definite left ventricular hypertrophy by Estes' criteria (restecg=2)."@en .

# =============================================================================
# Named Individuals - ST Slope
# =============================================================================

hdo:Upsloping rdf:type owl:NamedIndividual , hdo:STSlope ;
    rdfs:label "Upsloping"@en ;
    rdfs:comment "Upsloping peak exercise ST segment (slope=0)."@en .

hdo:FlatSlope rdf:type owl:NamedIndividual , hdo:STSlope ;
    rdfs:label "Flat"@en ;
    rdfs:comment "Flat peak exercise ST segment (slope=1)."@en .

hdo:Downsloping rdf:type owl:NamedIndividual , hdo:STSlope ;
    rdfs:label "Downsloping"@en ;
    rdfs:comment "Downsloping peak exercise ST segment (slope=2)."@en .

# =============================================================================
# Named Individuals - Thalassemia Types
# =============================================================================

hdo:NormalThal rdf:type owl:NamedIndividual , hdo:ThalassemiaType ;
    rdfs:label "Normal"@en ;
    rdfs:comment "Normal thalassemia result (thal=1)."@en .

hdo:FixedDefect rdf:type owl:NamedIndividual , hdo:ThalassemiaType ;
    rdfs:label "Fixed Defect"@en ;
    rdfs:comment "Fixed defect in thalassemia test (thal=2)."@en .

hdo:ReversibleDefect rdf:type owl:NamedIndividual , hdo:ThalassemiaType ;
    rdfs:label "Reversible Defect"@en ;
    rdfs:comment "Reversible defect in thalassemia test (thal=3)."@en .
